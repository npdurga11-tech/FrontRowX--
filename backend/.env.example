# Backend Environment Variables
# Copy this file to .env and edit as needed

# App
DEBUG=True

# PostgreSQL Database
DATABASE_URL=postgresql://frontrowx:frontrowx123@db:5432/frontrowx_db

# Redis
REDIS_URL=redis://redis:6379/0

# JWT
SECRET_KEY=change-this-to-a-random-secret-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Celery (uses Redis as broker)
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# Email (leave SMTP_PASSWORD empty to use console simulation)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@frontrowx.com
SMTP_PASSWORD=
ADMIN_EMAIL=admin@frontrowx.com
