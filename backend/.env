# Backend .env — used by Docker Compose and local development
# This file is committed for demo purposes only.
# In production, never commit real secrets.

DEBUG=False
ENV=production
# PostgreSQL (Docker service name is 'db')
DATABASE_URL=postgresql://frontrowx:frontrowx123@db:5432/frontrowx_db

# Redis (Docker service name is 'redis')
